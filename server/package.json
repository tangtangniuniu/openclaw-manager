{
  "name": "openclaw-manager-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-vm-modules --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "express": "^4.21.1",
    "json5": "^2.2.3",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/tar": "^6.1.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
